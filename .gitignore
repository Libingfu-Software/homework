# Arduino IDE 编译临时文件
*.ino.cpp
*.ino.o
*.ino.eep
*.elf
*.hex
*.d
*.a
*.o
__vm.*
*.prefs
*.core
*.build
**/build/

# PlatformIO 项目
.pio/
.pioenvs/
.piolibdeps/
.pythonlibs/
.vscode/.browse.c_cpp.db*
.cache/

# ESP-IDF（若混用）
build/
sdkconfig
sdkconfig.old
*.bin
*.map
**/partition_table/**/*.bin

# 依赖库（通常应显式声明，不提交库源码）
lib/  # 如果是临时复制的外部库
libraries/  # Arduino libraries 位置，建议通过 dependencies 管理

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~
desktop.ini

# IDE 配置文件
.vscode/  # 除非共享团队工作区，否则忽略
.idea/
*.code-workspace

# 串口/日志输出
*.log
*.txt  # 谨慎：如果项目中有重要 .txt 数据则需调整

# 临时文件
tmp/
temp/
*.bak
*.tmp